@article{sachweh_deserving_2025,
  title = {Deserving More? {{A}} Vignette Study on the Role of Self-Interest and Deservingness Opinions for Popular Support for Wealth Taxation in {{Germany}}},
  shorttitle = {Deserving More?},
  author = {Sachweh, Patrick and Eicher, Debora},
