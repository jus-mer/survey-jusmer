@article{berens_ethnic_2024,
  title = {Ethnic, {{Linguistic}}, and {{Religious Heterogeneity}} and {{Preferences}} for {{Public Goods}} and {{Redistribution}} in {{Latin America}}},
  author = {Berens, Sarah and Brady, David},
