@book{rothstein_just_1998,
  title = {Just {{Institutions Matter}}: {{The Moral}} and {{Political Logic}} of the {{Universal Welfare State}}},
  shorttitle = {Just {{Institutions Matter}}},
  author = {Rothstein, Bo},
  year = 1998,
