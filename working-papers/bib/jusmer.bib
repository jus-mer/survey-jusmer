@misc{iturra_perceptions_2023,
  type = {{{ESRA}}},
  title = {Perceptions and Preferences about Income Taxes: A Factorial Survey Approach},
  author = {Iturra, Julio and Castillo, Juan-Carlos and Maldonado, Luis},
  year = 2023,
  month = jul,
  address = {Mil\'an},
  abstract = {Concerns about increasing economic inequality have boosted the research on public perceptions and preferences related to salaries, social welfare, meritocracy, subjective status, and taxes. Traditional survey questions addressing this last topic generally rely on single-item Likert scales that ask to what extent respondents agree with the amount of taxes that are/should be paid by, for example, themselves, the poor, or the rich. Nevertheless, what respondents take into account when making judgments about just taxes remains largely unclear. The present study aims to shed light on how perceptions and preferences about taxes are related to specific characteristics of the presented (stimulus) case. Based on a two-wave factorial survey design in Chile in 2019 (N=1,470) we evaluated the role of characteristics such as gender, age, childcare, education, income, and family background on the perception and evaluation of a just income tax. The models were estimated in a multilevel framework, in which vignettes are nested within respondents in order to assess the influence of the vignette's attributes on perceived and preferred income tax. Preliminary results show that respondents tend to be well-informed and accurate about Chile's income tax levels. The vignette's household income is the most relevant attribute in explaining the perceived and preferred income tax, showing a robust positive effect. On the other hand, neither the respondent's educational level nor household income influences perceived and preferred income tax. The study was pre-registered in the Open Science Framework: https://osf.io/vpz86}
}

@article{iturra-sanhueza_classbased_2025,
  title = {Class-Based Network Segregation, Economic Inequality, and Redistributive Preferences across Societies},
  author = {{Iturra-Sanhueza}, Julio},
  year = 2025,
  month = nov,
  journal = {European Sociological Review},
  pages = {jcaf048},
  issn = {0266-7215, 1468-2672},
  doi = {10.1093/esr/jcaf048},
  urldate = {2025-11-24},
  abstract = {Abstract             Rising economic inequality has renewed interest in how class-based social networks shape redistributive preferences across societies. While previous research has explored how social class influences individual attitudes towards redistribution, less is known about how class-based network segregation---defined as the extent to which network ties belong to the same or similar social class of the individual---affects this relationship. At the national level, there is limited understanding of how income inequality could moderate how individuals at both ends of the class spectrum form redistributive attitudes within segregated networks. For example, in more segregated networks, the working class may experience heightened marginalization, while the service class may have reduced exposure to disadvantaged classes. This can deepen class-based attitudinal divides, particularly in societies with low to moderate inequality. However, in highly unequal societies, existing evidence suggests that the class gradient in redistributive preferences tends to narrow, primarily due to rising support for redistribution among the service class. This study investigates how income inequality moderates the interplay between social class and class-based network segregation in shaping redistributive preferences. Using cross-national data from 32,717 individuals across 31 countries, the findings reveal that homogeneous networks are associated with stronger redistributive support among the working class and weaker support among the service class. This relationship is mitigated in high-inequality contexts. Overall, the findings suggest that country-level inequality weakens the interaction between class-based network segregation and individual class position on redistributive attitudes, especially for the service class. The study underscores the value of integrating relational and structural approaches to better understand class, inequality, and support for redistribution.},
  copyright = {https://academic.oup.com/pages/standard-publication-reuse-rights},
  langid = {english},
  file = {C:\Users\renec\Zotero\storage\VH4MY7FV\Iturra-Sanhueza - 2025 - Class-based network segregation, economic inequality, and redistributive preferences across societie.pdf}
}

@article{iturra-sanhueza_social_2026,
  title = {Social Hierarchies and Meritocracy: Objective Status and the Moderating Role of Subjective Social Status on Perceived Meritocracy},
  shorttitle = {Social Hierarchies and Meritocracy},
  author = {{Iturra-Sanhueza}, Julio and Castillo, Juan Carlos and {Garc{\'i}a-Castro}, Juan Diego},
  year = 2026,
  month = apr,
  journal = {Frontiers in Sociology},
  volume = {11},
  publisher = {Frontiers},
  issn = {2297-7775},
  doi = {10.3389/fsoc.2026.1750965},
  urldate = {2026-05-06},
  abstract = {This study investigates how subjective and objective dimensions of social status affect perceptions of meritocracy in Chile's highly unequal society. Using data from the 2018 wave of the Longitudinal Social Study of Chile (ELSOC; N = 3,488), it examines whether individuals' beliefs about social status correlate with perceptions that effort and talent are rewarded, even when controlling for income and education. Grounded in the Reference Group and Reality (R\&R) blend hypothesis (Evans 2004; Evans et al. 1992), the analysis shows that subjective status is positively associated with perceived meritocracy. However, the evidence for objective status is more complex. While income often correlates with heightened perceptions of meritocracy---suggesting that individuals attribute their success to effort and talent (the self-interest hypothesis)---the results indicate a weak, statistically non-significant relationship when considering household income deciles. Alternative measures reflect modest differences in the expected direction. In terms of education, although it can reinforce meritocratic ideals (socialization hypothesis), it can also foster critical views by increasing awareness of structural inequalities (instruction hypothesis). Our findings support the latter, revealing that higher education levels are linked to lower perceptions of meritocracy. Moreover, subjective status moderates the relationship between objective status and perceived meritocracy. Individuals with higher income or educational attainment perceive greater meritocracy only when they identify as having higher status. Conversely, those in advantageous positions with low subjective status express lower perceived meritocracy. These findings highlight the significance of social comparison and self-perception in legitimizing or contesting meritocratic perceptions, particularly among upper-status groups. The study contributes to the literature on social stratification and attitudes towards inequality by discussing the assumptions of rational self-interest and emphasizing the psychosocial mechanisms underlying status perception. It expands the research scope beyond Western contexts by examining these dynamics in Chile, showing that subjective social status is crucial for understanding perceptions of meritocracy. Limitations and future research directions, especially regarding social networks and status misperception, are also discussed.},
  langid = {english},
  keywords = {Education,Income,meritocracy,Socioeconomic status,subjective social status}
}

@article{jacques_responding_2026,
  title = {Responding to Growing Health Care Costs: {{Public}} Preferences in Four {{OECD}} Countries},
  shorttitle = {Responding to Growing Health Care Costs},
  author = {Jacques, Olivier and Baute, Sharon and Busemeyer, Marius and Weisstanner, David},
  year = 2026,
  month = jun,
  journal = {SSM - Health Systems},
  volume = {6},
  pages = {100211},
  issn = {2949-8562},
  doi = {10.1016/j.ssmhs.2026.100211},
  urldate = {2026-05-11},
  abstract = {Introduction Growing health care cost has been a crucial issue for the governments of advanced democracies. This article analyzes public preferences for reforms surrounding growing health care costs. The main contribution of the study is to analyze how preferences for health reforms vary between the voters of different parties. Methods The study relies on an original survey conducted in four OECD countries representing different types of health care systems: Canada, Germany, Switzerland and the United Kingdom (England). Respondents were asked to choose between the allocation of more resources to the health care system (with higher taxes, contributions or user fees) or cutbacks in curative care or prevention. Results While all partisan groups oppose cutbacks to curative care, we find substantial partisan polarization in the reform choices between left-wing/green partisans and right-wing partisans. Left-wing partisans prefer higher taxes to avoid cutbacks, whereas right-wing partisans, in particular those of the populist right, prefer cutbacks to health promotion activities to avoid higher taxes. We also find that respondents who are satisfied with health care are more likely to accept increasing taxes or contributions to avoid cuts. We find significantly lower support for the allocation of additional resources to avoid cutbacks in Switzerland, a system characterized by regressive financing, and find stronger partisan polarization in Canada and England. Conclusion There are clear differences between the supporters of different parties regarding reform options as a response to growing health care costs, particularly regarding higher taxes to avoid cutbacks in prevention and health promotion.},
  keywords = {Cost containment,Health satisfaction,Health systems,Partisanship,Public opinion},
  file = {C\:\\Users\\renec\\Zotero\\storage\\Q3XE5JM4\\Jacques et al. - 2026 - Responding to growing health care costs Public preferences in four OECD countries.pdf;C\:\\Users\\renec\\Zotero\\storage\\XVHTXWHB\\S2949856226000450.html}
}

