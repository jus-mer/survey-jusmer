@article{moyanodavila_merit_2025,
  title = {Merit as an {{Attitude}}: {{Chilean School Communities}}' {{Repertoires}} in {{Chile}} and the {{Perception}} of the ``{{Good Student}}'' in a {{Post-pandemic Scenario}}},
  shorttitle = {Merit as an {{Attitude}}},
  author = {Moyano D{\'a}vila, Camila and {Alarc{\'o}n-Arcos}, Samanta and Angelcos, Nicol{\'a}s and Castillo, Juan Carlos and Salgado, Mauricio},
