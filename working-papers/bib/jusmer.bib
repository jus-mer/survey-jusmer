@article{borges_school_2025,
  title = {School {{Merit}} and {{Excellence Beyond Appearances}}},
  author = {Borges, Germano and Lima Torres, Leonor},
  year = 2025,
  month = dec,
  journal = {Revista Internacional de Educaci\'on para la Justicia Social},
  volume = {14},
  number = {2},
  issn = {2254-3139},
  doi = {10.15366/riejs2025.14.2.007},
  urldate = {2026-03-02},
  abstract = {This article aims to examine the representations of students distinguished for their academic merit regarding their educational trajectory in secondary schooling, with particular emphasis on the processes through which academic excellence is constructed. The study is framed within the interpretive paradigm and employs a case study strategy in a longitudinal perspective, drawing on a questionnaire survey (N=411), individual interviews (n=11), and research diary records. The qualitative analysis, grounded in thematic content analysis, enabled the organisation of categories around dimensions such as school performance, prior academic preparation, expectations, pressure for results, school competition, and the role of families. The findings reveal that students perceive secondary education as a stage of intense competitive pressure, dominated by a performative logic centred on grades and distinctions, often reinforced by private tutoring, grade inflation, and the creation of homogeneous classes. This environment generated intellectual, psychological, and physical strain, while limiting students' preparation for the transition to higher education. The discussion highlights the ``latent face'' of school excellence, in which school practices intersect with family strategies, contributing to the reproduction of inequalities despite the meritocratic rhetoric of fairness and equal opportunities.           ,              Este art\'iculo examina las representaciones de los estudiantes distinguidos por su m\'erito acad\'emico en relaci\'on con su trayectoria educativa en la ense\~nanza secundaria, con \'enfasis en los procesos de construcci\'on de la excelencia acad\'emica. El estudio se enmarca en el paradigma interpretativo y emplea una estrategia metodol\'ogica de estudio de casos en una perspectiva longitudinal, basada en un cuestionario (N=411), entrevistas individuales (n=11) y registros de un diario de investigaci\'on. El an\'alisis cualitativo, sustentado en el an\'alisis de contenido tem\'atico, permiti\'o organizar categor\'ias en torno a dimensiones como el rendimiento escolar, la preparaci\'on acad\'emica previa, las expectativas, la presi\'on por los resultados, la competencia escolar y el papel de las familias. Los hallazgos muestran que los estudiantes perciben la educaci\'on secundaria como una etapa de intensa presi\'on competitiva, dominada por una l\'ogica performativa centrada en calificaciones y distinciones, reforzada por clases particulares, inflaci\'on de notas y creaci\'on de clases homog\'eneas. Este entorno gener\'o desgaste intelectual, psicol\'ogico y f\'isico, limitando la preparaci\'on para la transici\'on a la educaci\'on superior. La discusi\'on resalta la ``cara latente'' de la excelencia escolar, donde pr\'acticas escolares y estrategias familiares convergen, reproduciendo desigualdades pese a la ret\'orica meritocr\'atica de justicia e igualdad de oportunidades.           ,              Este artigo examina as representa\c c\~oes dos alunos distinguidos pelo seu m\'erito acad\'emico em rela\c c\~ao \`a sua trajet\'oria educativa no ensino secund\'ario, com \^enfase nos processos de constru\c c\~ao da excel\^encia acad\'emica. O estudo enquadra-se no paradigma interpretativo e emprega uma estrat\'egia metodol\'ogica de estudo de casos numa perspetiva longitudinal, baseada num question\'ario (N=411), entrevistas individuais (n=11) e registos de um di\'ario de investiga\c c\~ao. A an\'alise qualitativa, sustentada na an\'alise de conte\'udo tem\'atico, permitiu organizar categorias em torno de dimens\~oes como desempenho escolar, prepara\c c\~ao acad\'emica pr\'evia, expectativas, press\~ao por resultados, competi\c c\~ao escolar e papel das fam\'ilias. Os resultados mostram que os estudantes percebem o ensino secund\'ario como uma etapa de intensa press\~ao competitiva, dominada por uma l\'ogica performativa centrada em notas e distin\c c\~oes, refor\c cada por aulas particulares, infla\c c\~ao de notas e cria\c c\~ao de turmas homog\'eneas. Este ambiente gerou desgaste intelectual, psicol\'ogico e f\'isico, limitando a prepara\c c\~ao para a transi\c c\~ao para o ensino superior. A discuss\~ao destaca o <<lado latente>> da excel\^encia escolar, onde pr\'aticas escolares e estrat\'egias familiares convergem, reproduzindo desigualdades apesar da ret\'orica meritocr\'atica de justi\c ca e igualdade de oportunidades.},
  copyright = {http://creativecommons.org/licenses/by-nc-nd/4.0}
}

